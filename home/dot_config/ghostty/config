#theme = "light:Flexoki Light,dark:Rose Pine Moon"
theme = "Rose Pine Moon"
cursor-color = "#ffffff"

font-family = "Berkeley Mono"

keybind = global:cmd+ctrl+grave_accent=toggle_quick_terminal

macos-option-as-alt = true

unfocused-split-opacity = .4

# Shift+Enter: no custom keybind needed when running pi directly in Zellij.
# When running through tmux, tmux's extended-keys always + csi-u handles it.
# If issues persist, uncomment to force modifyOtherKeys format through all layers:
#keybind = shift+enter=text:\x1b[27;2;13~

shell-integration = fish
command = /opt/homebrew/bin/fish
