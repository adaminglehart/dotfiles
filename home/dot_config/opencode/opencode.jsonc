{
  "$schema": "https://opencode.ai/config.json",
  // "model": "anthropic/claude-sonnet-4-5",
  // "small_model": "anthropic/claude-haiku-4-5",
  "theme": "flexoki",
    "autoupdate": false,
  "share": "disabled",
  "model": "stripe-anthropic/claude-opus-4.6",
  "enabled_providers": ["stripe-anthropic", "stripe-openai", "stripe-google"],
  "instructions": ["CLAUDE.md", "AGENTS.md", ".cursor/rules/*.md"],
  "provider": {
    "stripe-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "name": "Stripe Anthropic",
      "options": {
        "baseURL": "http://litellm.qa.corp.stripe.com.certproxy.localhost:7891/v1",
        "apiKey": "use_case=development&team=privy-a",
      },
      "models": {
        "claude-sonnet-4.5": {
          "name": "Claude Sonnet 4.5",
          "limit": { "context": 200000, "output": 65536 },
        },
        "claude-opus-4.5": {
          "name": "Claude Opus 4.5",
          "limit": { "context": 200000, "output": 32768 },
        },
        "claude-opus-4.6": {
          "name": "Claude Opus 4.6",
          "limit": { "context": 200000, "output": 32768 },
        },
        "claude-opus-4.6-1m": {
          "name": "Claude Opus 4.6 1M",
          "limit": { "context": 1000000, "output": 32768 },
        },
      },
    },
    // GPT models use @ai-sdk/openai (native OpenAI SDK) instead of
    // @ai-sdk/openai-compatible to avoid hanging issue with tool calls
    "stripe-openai": {
      "npm": "@ai-sdk/openai",
      "name": "Stripe OpenAI",
      "options": {
        "baseURL": "%%BASE_URL%%",
        "apiKey": "%%API_KEY%%",
      },
      "models": {
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
        },
        "gpt-5.1-codex": {
          "name": "GPT-5.1 Codex",
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
        },
        "gpt-5": {
          "name": "GPT-5",
        },
      },
    },
    "stripe-google": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Stripe Google",
      "options": {
        "baseURL": "http://litellm.qa.corp.stripe.com.certproxy.localhost:7891/v1",
        "apiKey": "use_case=development&team=privy-a",
      },
      "models": {
        "gemini-3-pro": {
          "name": "Gemini 3 Pro",
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash",
        },
      },
    },

    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://10.0.10.35:11434/v1",
      },
      "models": {
        "qwen3:8b": {
          "tools": true,
        },
        "gemma3:4b": {
          "limit": {
            "context": 32768,
            "output": 65536,
          },
        },
      },
    },
  },
  
}


