sourceDir: ~/dev/dotfiles/
cacheDir: ~/.cache/chezmoi-dotfiles
persistentState: ~/.config/chezmoi-dotfiles/chezmoistate.boltdb
diff:
  pager: "delta"
  command: "diff"
  args:
    - "-u"
    - "--ignore-all-space"
    - '{{ "{{" }} .Destination {{ "}}" }}'
    - '{{ "{{" }} .Target {{ "}}" }}'
merge:
  command: "bash"
  args:
    - "-c"
    - 'cp {{ "{{" }} .Target | quote {{ "}}" }} {{ "{{" }} printf "%s.base" .Target | quote {{ "}}" }} && code --new-window --wait --merge {{ "{{" }} .Destination | quote {{ "}}" }} {{ "{{" }} .Target | quote {{ "}}" }} {{ "{{" }} printf "%s.base" .Target | quote {{ "}}" }} {{ "{{" }} .Source | quote {{ "}}" }}'
data:
  environment: {{ .environment | quote }}
