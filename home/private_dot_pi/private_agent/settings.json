{
  "lastChangelogVersion": "0.58.4",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-6",
  "packages": ["npm:@plannotator/pi-extension", "npm:pi-self-learning"],
  "enabledModels": [
    "anthropic/claude-sonnet-4-6",
    "anthropic/claude-opus-4-6",
    "google/gemini-2.5-flash",
    "anthropic/claude-haiku-4-5",
    "openai/gpt-5.4",
    "openai/gpt-5.4-pro"
  ],
  "selfLearning": {
    "enabled": true,
    "autoAfterTask": true,
    "injectLastN": 5,
    "maxCoreItems": 20,
    "storage": {
      "mode": "global",
      "globalPath": "~/Documents/obsidian/agents/learnings"
    },
    "git": {
      "enabled": false
    },
    "context": {
      "enabled": true,
      "includeCore": true,
      "includeLastNDaily": 2,
      "maxChars": 12000,
      "instructionMode": "strict"
    },
    "model": {
      "provider": "google",
      "id": "gemini-2.5-flash"
    }
  }
}
