{
  "lastChangelogVersion": "0.61.0",
  "packages": ["npm:@plannotator/pi-extension", "npm:pi-self-learning"],
  "extensions": [
    "~/.config/pi/bake/pi-extension/status-writer.ts"
  ],
  "selfLearning": {
    "enabled": true,
    "autoAfterTask": true,
    "injectLastN": 5,
    "maxCoreItems": 20,
    "git": {
      "enabled": false
    },
    "context": {
      "enabled": true,
      "includeCore": true,
      "includeLastNDaily": 2,
      "maxChars": 12000,
      "instructionMode": "strict"
    }
  }
}
