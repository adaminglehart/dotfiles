{
  "lastChangelogVersion": "0.62.0",
  "packages": [
    "npm:@plannotator/pi-extension",
    "npm:pi-self-learning",
    "npm:glimpseui"
  ],
  "extensions": [
    "~/.config/pi/bake/pi-extension/status-writer.ts"
  ],
  "selfLearning": {
    "enabled": true,
    "autoAfterTask": true,
    "injectLastN": 0,
    "maxCoreItems": 20,
    "git": {
      "enabled": false
    },
    "context": {
      "enabled": true,
      "includeCore": true,
      "includeLastNDaily": 2,
      "maxChars": 12000,
      "instructionMode": "strict"
    },
    "storage": {
      "mode": "global",
      "globalPath": "~/Documents/obsidian/agents/learnings"
    }
  },
  "hideThinkingBlock": true,
  "librarian": {
    "maxTurns": 10,
    "maxSearchResults": 30
  },
  "quietStartup": true
}
